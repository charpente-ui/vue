{
    "name": "@charpente-ui/vue",
    "version": "2.1.1",
    "description": "Charpente UI is a headless Vue component library.",
    "type": "module",
    "scripts": {
        "dev": "vite --config playground/vite.config.ts",
        "lint:js": "eslint --fix .",
        "lint": "npm-run-all --parallel lint:*",
        "build": "vite build",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:all": "run-s test:coverage test:e2e",
        "prepare": "husky",
        "prepack": "npm run build",
        "release": "semantic-release"
    },
    "engines": {
        "node": ">=20"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.3",
        "@commitlint/config-conventional": "^20.5.3",
        "@front-factory/eslint-config": "^1.3.1",
        "@playwright/test": "^1.61.1",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.9",
        "@vitejs/plugin-vue": "^6.0.8",
        "@vitest/coverage-v8": "^4.1.10",
        "@vue/test-utils": "^2.4.11",
        "conventional-changelog-conventionalcommits": "^9.3.1",
        "eslint": "^10.7.0",
        "eslint-plugin-vue": "^10.10.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "npm-run-all2": "^8.0.4",
        "semantic-release": "^25.0.8",
        "typescript-eslint": "^8.65.0",
        "vite": "^8.1.5",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.10",
        "vue": "^3.5.40"
    },
    "peerDependencies": {
        "vue": "^3.5.0"
    },
    "keywords": [
        "vue",
        "components",
        "framework",
        "charpente",
        "ui",
        "headless"
    ],
    "license": "MIT",
    "homepage": "https://github.com/charpente-ui/vue",
    "bugs": {
        "url": "https://github.com/charpente-ui/vue/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/charpente-ui/vue.git"
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
