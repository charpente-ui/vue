{
    "name": "@charpente-ui/vue",
    "version": "1.4.1",
    "description": "Charpente UI is a headless CSS Vue component library.",
    "type": "module",
    "scripts": {
        "dev": "vite --config playground/vite.config.ts",
        "lint:js": "eslint --fix .",
        "lint": "npm-run-all --parallel lint:*",
        "build": "vite build",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepare": "husky && npm run build",
        "release": "semantic-release"
    },
    "engines": {
        "node": ">=24"
    },
    "main": "./dist/charpente.umd.cjs",
    "module": "./dist/charpente.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/charpente.js",
            "require": "./dist/charpente.umd.cjs"
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@front-factory/eslint-config": "^1.3.1",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.6",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vitest/coverage-v8": "^4.1.5",
        "@vue/test-utils": "^2.4.9",
        "conventional-changelog-conventionalcommits": "^9.1.0",
        "eslint": "^10.0.2",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.0",
        "npm-run-all2": "^8.0.4",
        "semantic-release": "^25.0.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^8.0.10",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.5",
        "vue": "^3.5.29"
    },
    "peerDependencies": {
        "vue": "^3.0.0"
    },
    "keywords": [
        "vue",
        "components",
        "framework",
        "charpente",
        "ui",
        "headless"
    ],
    "license": "MIT",
    "homepage": "https://github.com/charpente-ui/vue",
    "bugs": {
        "url": "https://github.com/charpente-ui/vue/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/charpente-ui/vue.git"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    }
}
